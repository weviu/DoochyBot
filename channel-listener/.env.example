# Telegram API credentials (from https://my.telegram.org -> API development tools)
API_ID=your_api_id
API_HASH=your_api_hash

# Phone number of the Telegram user account (international format, e.g. +14155551234).
# This account must already be a member of the SureShot Gold channel.
PHONE_NUMBER=+14155551234

# SureShot Gold channel identifier (public @username without the @).
CHANNEL_USERNAME=sureshotgold

# DoochyBot webhook endpoint that receives the formatted signal as text/plain.
WEBHOOK_URL=http://localhost:9009/webhook
