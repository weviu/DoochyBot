#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/san/doochybot/node_modules/.pnpm/protobufjs@5.0.1/node_modules/protobufjs/bin/node_modules:/home/san/doochybot/node_modules/.pnpm/protobufjs@5.0.1/node_modules/protobufjs/node_modules:/home/san/doochybot/node_modules/.pnpm/protobufjs@5.0.1/node_modules:/home/san/doochybot/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/san/doochybot/node_modules/.pnpm/protobufjs@5.0.1/node_modules/protobufjs/bin/node_modules:/home/san/doochybot/node_modules/.pnpm/protobufjs@5.0.1/node_modules/protobufjs/node_modules:/home/san/doochybot/node_modules/.pnpm/protobufjs@5.0.1/node_modules:/home/san/doochybot/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../bin/pbjs" "$@"
else
  exec node  "$basedir/../../bin/pbjs" "$@"
fi
